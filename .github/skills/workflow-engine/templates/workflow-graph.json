{
  "$schema": "../../../../tools/schemas/workflow-graph.schema.json",
  "description": "Multi-step Azure infrastructure workflow DAG — linear Bicep-only flow (governance as Step 3.5)",
  "nodes": {
    "step-1": {
      "id": "step-1",
      "type": "agent-step",
      "name": "Requirements",
      "agent": "02-Requirements",
      "requires": [],
      "produces": ["01-requirements.md"],
      "gate": "approval",
      "challenger": { "enabled": false, "passes": 1, "lenses": ["comprehensive"] }
    },
    "gate-1": {
      "id": "gate-1",
      "type": "gate",
      "name": "Requirements Approval",
      "requires": ["step-1"],
      "gate": "approval"
    },
    "step-2": {
      "id": "step-2",
      "type": "agent-step",
      "name": "Architecture",
      "agent": "03-Architect",
      "requires": ["gate-1"],
      "produces": ["02-architecture-assessment.md"],
      "gate": "approval",
      "challenger": {
        "enabled": false,
        "default_passes": 1,
        "default_lenses": ["comprehensive"],
        "opt_in_multi_pass": true,
        "complexity_matrix": {
          "simple": { "passes": 1, "lenses": ["comprehensive"] },
          "standard": {
            "passes": 2,
            "lenses": ["security-governance", "architecture-reliability"]
          },
          "complex": {
            "passes": 3,
            "lenses": [
              "security-governance",
              "architecture-reliability",
              "cost-feasibility"
            ]
          }
        }
      }
    },
    "gate-2": {
      "id": "gate-2",
      "type": "gate",
      "name": "Architecture Approval",
      "requires": ["step-2"],
      "gate": "approval"
    },
    "step-3_5": {
      "id": "step-3_5",
      "type": "agent-step",
      "name": "Governance",
      "agent": "04g-Governance",
      "requires": ["gate-2"],
      "produces": [
        "04-governance-constraints.md",
        "04-governance-constraints.json"
      ],
      "gate": "approval",
      "challenger": null
    },
    "gate-2_5": {
      "id": "gate-2_5",
      "type": "gate",
      "name": "Governance Approval",
      "requires": ["step-3_5"],
      "gate": "approval"
    },
    "step-4": {
      "id": "step-4",
      "type": "agent-step",
      "name": "IaC Plan",
      "agent": "05-IaC Planner",
      "requires": ["gate-2_5"],
      "produces": [
        "04-implementation-plan.md",
        "04-dependency-diagram.py",
        "04-dependency-diagram.png",
        "04-runtime-diagram.py",
        "04-runtime-diagram.png"
      ],
      "gate": "approval",
      "challenger": {
        "enabled": false,
        "default_passes": 0,
        "opt_in": true,
        "complexity_matrix": {
          "simple": { "passes": 1, "lenses": ["comprehensive"] },
          "standard": {
            "passes": 2,
            "lenses": ["security-governance", "architecture-reliability"]
          },
          "complex": {
            "passes": 2,
            "lenses": ["security-governance", "architecture-reliability"]
          }
        }
      }
    },
    "gate-3": {
      "id": "gate-3",
      "type": "gate",
      "name": "Plan Approval",
      "requires": ["step-4"],
      "gate": "approval"
    },
    "step-5": {
      "id": "step-5",
      "type": "agent-step",
      "name": "Bicep Code",
      "agent": "06b-Bicep CodeGen",
      "requires": ["gate-3"],
      "produces": ["infra/bicep/{project}/"],
      "gate": "validation",
      "challenger": {
        "enabled": false,
        "default_passes": 0,
        "opt_in": true,
        "complexity_matrix": {
          "simple": { "passes": 1, "lenses": ["comprehensive"] },
          "standard": {
            "passes": 2,
            "lenses": ["security-governance", "architecture-reliability"]
          },
          "complex": {
            "passes": 3,
            "lenses": [
              "security-governance",
              "architecture-reliability",
              "cost-feasibility"
            ]
          }
        }
      }
    },
    "step-6": {
      "id": "step-6",
      "type": "agent-step",
      "name": "Bicep Deploy",
      "agent": "07-Bicep Deploy",
      "requires": ["step-5"],
      "produces": ["06-deployment-summary.md"],
      "gate": "approval",
      "challenger": null
    },
    "step-7": {
      "id": "step-7",
      "type": "subagent-fan-out",
      "name": "As-Built Documentation",
      "agent": "08-As-Built",
      "requires": ["step-6"],
      "produces": [
        "07-design-document.md",
        "07-operations-runbook.md",
        "07-compliance-matrix.md",
        "07-backup-dr-plan.md",
        "07-resource-inventory.md",
        "07-documentation-index.md"
      ],
      "gate": null,
      "parallel_substeps": [
        "design-document",
        "operations-runbook",
        "compliance-matrix",
        "backup-dr-plan",
        "resource-inventory",
        "documentation-index"
      ]
    }
  },
  "edges": [
    { "from": "step-1", "to": "gate-1", "condition": "on_complete" },
    { "from": "gate-1", "to": "step-2", "condition": "on_complete" },
    { "from": "step-2", "to": "gate-2", "condition": "on_complete" },
    { "from": "gate-2", "to": "step-3_5", "condition": "on_complete" },
    { "from": "step-3_5", "to": "gate-2_5", "condition": "on_complete" },
    { "from": "gate-2_5", "to": "step-4", "condition": "on_complete" },
    { "from": "step-4", "to": "gate-3", "condition": "on_complete" },
    { "from": "gate-3", "to": "step-5", "condition": "on_complete" },
    { "from": "step-5", "to": "step-6", "condition": "on_complete" },
    { "from": "step-6", "to": "step-7", "condition": "on_complete" }
  ],
  "metadata": {
    "version": "3.0",
    "iac_tracks": ["Bicep"],
    "total_gates": 5,
    "total_steps": 7,
    "challenger_enabled": false,
    "challenger_disabled_reason": "Disabled for performance — challenger adds meaningful time to every run and is overkill for brownfield deployments of known patterns into existing infrastructure. Re-enable per-node via challenger.enabled and this flag for complex greenfield deployments.",
    "complexity_routing": {
      "description": "Deterministic formula for selecting challenger-review pass counts. Orchestrator computes `score` at gate-1, stores result in session state `decisions.complexity`, and agents read from session state instead of re-deriving.",
      "formula": "score = (resource_count / 3) + (policy_violations / 2)",
      "tiers": [
        { "max_score": 1.5, "label": "simple", "passes": 1 },
        { "max_score": 3.0, "label": "standard", "passes": 2 },
        { "max_score": 999, "label": "complex", "passes": 3 }
      ],
      "inputs": {
        "resource_count": "Count of Azure resources declared in 02-architecture-assessment.md",
        "policy_violations": "Count of `deny`-effect findings from 04-governance-constraints.json"
      }
    }
  }
}
